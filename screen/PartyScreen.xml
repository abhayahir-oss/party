<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
        default-menu-title="Party Screen">

    <transition name="self">
        <default-response url="."/>
    </transition>

    <transition name="createParty">
        <actions>
            <service-call name="create#party.Party" in-map="context" out-map="createPartyOut"/>
            <if condition="partyTypeEnumId == 'PERSON'">
                <service-call name="create#party.Person" in-map="[partyId:createPartyOut.partyId, firstName:firstName, lastName:lastName]"/>
            </if>
            <if condition="partyTypeEnumId == 'PARTY_GROUP'">
                <service-call name="create#party.PartyGroup" in-map="[partyId:createPartyOut.partyId, groupName:groupName]"/>
            </if>
        </actions>
        <default-response url="."/>
    </transition>

    <actions>
        <entity-find entity-name="party.Party" list="partyList">
            <search-form-inputs/>
        </entity-find>
    </actions>

    <widgets>
        <container style="margin-bottom: 20px;">
            <container-dialog id="CreatePartyDialog" button-text="Create Party">
                <form-single name="CreatePartyForm" transition="createParty">
                    <auto-fields-entity entity-name="party.Party" field-type="edit"/>

                    <field name="partyTypeEnumId">
                        <default-field title="Type">
                            <drop-down allow-empty="false">
                                <entity-options key="${enumId}" text="${description}">
                                    <entity-find entity-name="moqui.basic.Enumeration">
                                        <efilter field-name="enumTypeId" value="PartyType"/>
                                        <order-by field-name="description"/>
                                    </entity-find>
                                </entity-options>
                            </drop-down>
                        </default-field>
                    </field>

                    <field name="createdDate">
                        <default-field><ignored/></default-field>
                    </field>

                    <field name="firstName">
                        <default-field title="First Name (Person)"><text-line/></default-field>
                    </field>
                    <field name="lastName">
                        <default-field title="Last Name (Person)"><text-line/></default-field>
                    </field>
                    <field name="groupName">
                        <default-field title="Group Name (Organization)"><text-line/></default-field>
                    </field>

                    <field name="submitButton">
                        <default-field title="Create"><submit/></default-field>
                    </field>
                </form-single>
            </container-dialog>
        </container>

        <form-list name="ListParties" list="partyList" transition="self">
            <field name="partyId">
                <header-field show-order-by="true"><text-find/></header-field>
                <default-field><display/></default-field>
            </field>
            <field name="partyTypeEnumId">
                <header-field show-order-by="true"><text-find/></header-field>
                <default-field><display/></default-field>
            </field>
            <field name="createdDate">
                <header-field show-order-by="true"><date-find type="date-time"/></header-field>
                <default-field><display/></default-field>
            </field>
            <field name="submitButton">
                <header-field title="Find"><submit/></header-field>
                <default-field><ignored/></default-field>
            </field>
        </form-list>
    </widgets>
</screen>
